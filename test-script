-- [[ SETTINGS FLOWS ]]
-- ================================================================
local function GetMovePool(standName,styleName)
    local pool={}
    if standName and STAND_DATA[standName] then for _,m in ipairs(STAND_DATA[standName].moves) do table.insert(pool,m) end end
    if styleName and STYLE_DATA[styleName] then for _,m in ipairs(STYLE_DATA[styleName].moves) do if m.statusType~="heal" then table.insert(pool,m) end end end
    return pool
end

local function RunStorySettingsFlow()
    local standSlots=ScanStandStorage()
    ShowSlotPicker("Story — Choose Stand",standSlots,function(s1)
        CFG.storyStandName=s1.baseName
        local storyMoves=GetMovePool(CFG.storyStandName,LOCKED_STYLE)
        ShowPriorityBuilder("Priority — Enrico Pucci",storyMoves,CFG.pucciPriority,function(p1)
            CFG.pucciPriority=p1
            ShowPriorityBuilder("Priority — Tooru",storyMoves,CFG.tooruPriority,function(p2)
                CFG.tooruPriority=p2
                ShowSlotPicker("World Boss — Choose Stand",standSlots,function(s2)
                    CFG.wbStandName=s2.baseName
                    local styleSlots=ScanStyleStorage()
                    ShowSlotPicker("World Boss — Choose Style",styleSlots,function(s3)
                        CFG.wbStyleName=s3.baseName
                        local wbMoves=GetMovePool(CFG.wbStandName,CFG.wbStyleName)
                        ShowPriorityBuilder("Priority — World Boss",wbMoves,CFG.wbPriority,function(p3)
                            CFG.wbPriority=p3; ClosePopup()
                            SetStatus("Story config saved.",C.green)
                            task.delay(2,function() SetStatus("Idle") end)
                        end)
                    end)
                end)
            end)
        end)
    end)
end

local function RunDungeonSettingsFlow()
    local standSlots=ScanStandStorage()
    ShowSlotPicker("Dungeon — Choose Stand",standSlots,function(s1)
        CFG.dungeonStandName=s1.baseName
        local dungeonMoves=GetMovePool(CFG.dungeonStandName,LOCKED_STYLE)
        ShowPriorityBuilder("Priority — Dungeon",dungeonMoves,CFG.dungeonPriority,function(p1)
            CFG.dungeonPriority=p1; ClosePopup()
            SetStatus("Dungeon config saved.",C.green)
            task.delay(2,function() SetStatus("Idle") end)
        end)
    end)
end

