-- [[ LOADOUT ENFORCEMENT ]]
-- B change: EnsureStand/EnsureStyle now use CFG names resolved to slots at runtime
-- ================================================================
local function FleeAnyActiveBattle()
    if IsInStoryBattle() then
        StoryUseSkill("Flee"); task.wait(1)
    elseif IsInDungeonBattle() then
        TryFleeFromDungeon(); task.wait(0.5)
    end
end

local function EnsureStyle(targetStyle)
    if CurrentStyle == targetStyle then return end
    FleeAnyActiveBattle()
    local slot = FindStyleSlot(targetStyle)
    if slot then
        StandStorageAction:FireServer("SwapStyle", slot)
    else
        SwapStyle(1) -- fallback
    end
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited = waited + 0.3
        DetectLoadoutFromInventory()
        if CurrentStyle == targetStyle then return end
    end
end

local function EnsureStand(targetStand)
    if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    local slot = FindStandSlot(targetStand)
    if not slot then return end
    FleeAnyActiveBattle()
    StandStorageAction:FireServer("Swap", slot)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited = waited + 0.3
        DetectLoadoutFromInventory()
        if CurrentStand:upper():find(targetStand:upper(), 1, true) then return end
    end
end

local function EnforceStoryLoadout()
    if not IsInStoryBattle() then FleeAnyActiveBattle() end
    DetectLoadoutFromInventory()
    if CFG.storyStandName then EnsureStand(CFG.storyStandName) end
    EnsureStyle("ULF")
end

local function EnforceDungeonLoadout()
    if not IsInDungeonBattle() then FleeAnyActiveBattle() end
    DetectLoadoutFromInventory()
    if CFG.dungeonStandName then EnsureStand(CFG.dungeonStandName) end
    EnsureStyle("ULF")
end

-- ================================================================
-- [[ SHARED SURVIVAL CHECK ]] -- unchanged from Proto A
-- ================================================================
local function HandleSurvival(ctx)
    local _, _, hpPct = GetHP(ctx)

    if hpPct < HP_DANGER then
        if     CanUse(ctx,"Instant Reformation") then UseSkill(ctx,"Instant Reformation")
        elseif CanUse(ctx,"Block")               then UseSkill(ctx,"Block")
        else                                          UseSkill(ctx,"Rest")
        end
        return true
    end

    if hpPct < HP_HEAL then
        if CanUse(ctx,"Instant Reformation") then
            ctx.HasBlockedThisDip = false
            UseSkill(ctx,"Instant Reformation"); return true
        end
        if not ctx.HasBlockedThisDip then
            ctx.HasBlockedThisDip = true
            if CanUse(ctx,"Block") then UseSkill(ctx,"Block"); return true end
        end
    else
        ctx.HasBlockedThisDip = false
    end

    return false
end

-- ================================================================
-- [[ PRIORITY EXECUTION ]] -- B addition: runs saved CFG priority list
-- Falls back to normal attack if nothing configured
-- ================================================================
local function ExecutePriority(ctx, priorityList)
    if not priorityList or #priorityList == 0 then return false end

    -- build move info lookup
    local standName = ctx == WorldBossCtx and CFG.wbStandName
                   or ctx == DungeonCtx   and CFG.dungeonStandName
                   or CFG.storyStandName
    local styleName = ctx == WorldBossCtx and CFG.wbStyleName or "Ultimate Lifeform"
    local moveMap = {}
    if standName and STAND_DATA[standName] then
        for _, m in ipairs(STAND_DATA[standName].moves) do moveMap[m.name] = m end
    end
    if styleName and STYLE_DATA[styleName] then
        for _, m in ipairs(STYLE_DATA[styleName].moves) do moveMap[m.name] = m end
    end

    local energy, stamina = GetResources(ctx)

    for _, moveName in ipairs(priorityList) do
        if CanUse(ctx, moveName) then
            local m = moveMap[moveName]
            local skip = false

            if m then
                if m.cost == "energy"  and energy  < STORY_ENERGY_THRESHOLD then skip = true end
                if m.cost == "stamina" and stamina < STAMINA_THRESHOLD       then skip = true end

                if not skip then
                    local st = m.statusType
                    if st == "confusion" then
                        if EnemyIsConfImmune(ctx) or EnemyIsConfused(ctx) then skip = true end
                    elseif st == "stun" then
                        if EnemyIsStunImmune(ctx) or EnemyIsStunned(ctx) then skip = true end
                    elseif st == "burn" then
                        if EnemyStatusDur(ctx,"Burn") > 1 then skip = true end
                    elseif st == "bleed" then
                        if EnemyStatusDur(ctx,"Bleed") > 1 then skip = true end
                    end
                end
            end

            if not skip then
                UseSkill(ctx, moveName); return true
            end
        end
    end

    return false
end

-- ================================================================
-- [[ COMBAT ENGINE — STORY ]]
-- B change: Pucci and Tooru use CFG priority if set, else falls back to Proto A logic
-- ================================================================
local function RunStoryCombatTick()
    local ctx             = StoryCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    local enemy = GetStoryEnemyName()

    -- Enrico Pucci: use CFG priority if set
    if enemy == "Enrico Pucci" then
        if #CFG.pucciPriority > 0 then
            if ExecutePriority(ctx, CFG.pucciPriority) then return end
        else
            -- Proto A fallback
            if hasEnergy and CanUse(ctx,"Illusory Presence") then
                if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                    UseSkill(ctx,"Illusory Presence"); return
                end
            end
            if hasEnergy and CanUse(ctx,"Golden Spin") then
                if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                    UseSkill(ctx,"Golden Spin"); return
                end
            end
        end
        if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    -- Tooru: use CFG priority if set
    if enemy == "Tooru" and not PrestigeEnabled then
        if #CFG.tooruPriority > 0 then
            if ExecutePriority(ctx, CFG.tooruPriority) then return end
        else
            -- Proto A fallback
            if hasEnergy and CanUse(ctx,"Illusory Presence") then
                if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                    UseSkill(ctx,"Illusory Presence"); return
                end
            end
            if hasEnergy and CanUse(ctx,"Rain of Debris") then UseSkill(ctx,"Rain of Debris"); return end
            if hasEnergy and CanUse(ctx,"Golden Spin") then
                if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                    UseSkill(ctx,"Golden Spin"); return
                end
            end
            if hasStamina and CanUse(ctx,"Melting Overdrive") then
                if not EnemyIsBurning(ctx) then UseSkill(ctx,"Melting Overdrive"); return end
            end
        end
        if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end
        UseSkill(ctx,"Rest"); return
    end

    -- All other enemies: normal attack only
    if hasEnergy and CanUse(ctx,"Infinite Rotation") then
        UseSkill(ctx,"Infinite Rotation"); return
    end

    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ COMBAT ENGINE — DUNGEON ]]
-- B change: use CFG dungeonPriority if set, else Proto A logic
-- ================================================================
local function RunDungeonCombatTick()
    local ctx             = DungeonCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= DUNGEON_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if #CFG.dungeonPriority > 0 then
        if ExecutePriority(ctx, CFG.dungeonPriority) then return end
    else
        -- Proto A fallback
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                UseSkill(ctx,"Illusory Presence"); return
            end
        end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                UseSkill(ctx,"Golden Spin"); return
            end
        end
        if hasStamina and CanUse(ctx,"Melting Overdrive") then
            if not EnemyIsBurning(ctx) then UseSkill(ctx,"Melting Overdrive"); return end
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end

    if not hasEnergy and hasStamina then
        if CanUse(ctx,"Melting Overdrive") then UseSkill(ctx,"Melting Overdrive"); return end
        UseSkill(ctx,"Rest"); return
    end

    UseSkill(ctx,"Rest")
end

-- ================================================================
-- [[ COMBAT ENGINE — WORLD BOSS ]]
-- B change: use CFG wbPriority if set, else Proto A logic
-- ================================================================
local function RunWorldBossTick()
    local ctx             = WorldBossCtx
    local energy, stamina = GetResources(ctx)

    if IsPlayerIncapacitated(ctx) then UseSkill(ctx,"Rest"); return end
    if IsConfused(ctx)            then UseSkill(ctx,"Rest"); return end
    if HandleSurvival(ctx)        then return end

    local hasEnergy  = energy  >= STORY_ENERGY_THRESHOLD
    local hasStamina = stamina >= STAMINA_THRESHOLD

    if not hasEnergy and not hasStamina then UseSkill(ctx,"Rest"); return end

    if #CFG.wbPriority > 0 then
        if ExecutePriority(ctx, CFG.wbPriority) then return end
    else
        -- Proto A fallback
        if hasEnergy and CanUse(ctx,"Illusory Presence") then
            if not EnemyIsConfImmune(ctx) and not EnemyIsConfused(ctx) then
                UseSkill(ctx,"Illusory Presence"); return
            end
        end
        if hasEnergy and CanUse(ctx,"Rain of Debris") then UseSkill(ctx,"Rain of Debris"); return end
        if hasEnergy and CanUse(ctx,"Golden Spin") then
            if not EnemyIsStunImmune(ctx) and not EnemyIsStunned(ctx) then
                UseSkill(ctx,"Golden Spin"); return
            end
        end
        if hasStamina and CanUse(ctx,"Malevolent Shrine") then
            if EnemyStatusDur(ctx,"Bleed") <= 1 then UseSkill(ctx,"Malevolent Shrine"); return end
        end
        if hasStamina and CanUse(ctx,"Divine Flame") then
            if EnemyStatusDur(ctx,"Burn") <= 1 then UseSkill(ctx,"Divine Flame"); return end
        end
    end

    if hasEnergy and CanUse(ctx,"Infinite Rotation") then UseSkill(ctx,"Infinite Rotation"); return end

    if not hasEnergy and hasStamina then
        if     CanUse(ctx,"Malevolent Shrine") then UseSkill(ctx,"Malevolent Shrine"); return
        elseif CanUse(ctx,"Divine Flame")      then UseSkill(ctx,"Divine Flame");      return
        else                                        UseSkill(ctx,"Rest");              return
        end
    end

    UseSkill(ctx,"Rest")
end

