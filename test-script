local function GetPlayerFighter(ctx)
    return SafeGet(ctx.Root(), "HealthbarArea","AlliesContainer","Fighter_Player")
end

local function GetEnemyFighter(ctx)
    return SafeGet(ctx.Root(), "HealthbarArea","EnemiesContainer","Fighter_Enemy")
end

local function IsInStoryBattle()
    return GetPlayerFighter(StoryCtx) ~= nil or GetEnemyFighter(StoryCtx) ~= nil
end

local function IsInDungeonBattle()
    return GetPlayerFighter(DungeonCtx) ~= nil and GetEnemyFighter(DungeonCtx) ~= nil
end

local function TryFleeFromDungeon()
    DungeonUseSkill("Flee")
    local logText = SafeGet(PlayerGui, table.unpack(DUNGEON_LOG_PATH))
    if not logText then task.wait(1); return false end
    local waited = 0
    while waited < 3 do
        if (logText.Text or ""):find("DUNGEON FLED!") then return true end
        task.wait(0.2); waited = waited + 0.2
    end
    return false
end

local function GetResources(ctx)
    local label = SafeGet(ctx.Root(), "ResourceLabel")
    if not label then return 0, 0 end
    local text    = label.Text or ""
    local energy  = tonumber(text:match("ENERGY:%s*(%d+)"))  or 0
    local stamina = tonumber(text:match("STAMINA:%s*(%d+)")) or 0
    return energy, stamina
end

local function GetHP(ctx)
    local fighter = GetPlayerFighter(ctx)
    if not fighter then return 999, 999, 1 end
    local hpText = SafeGet(fighter, "InfoArea","HpContainer","HpText")
    if not hpText then return 999, 999, 1 end
    local cur, max = (hpText.Text or ""):match("(%d+)%s*/%s*(%d+)")
    cur = tonumber(cur) or 999; max = tonumber(max) or 999
    return cur, max, (max > 0 and cur / max or 1)
end

local function GetStatusDuration(fighter, statusName)
    if not fighter then return 0 end
    local container = SafeGet(fighter, "InfoArea","StatusContainer")
    if not container then return 0 end
    local lower = statusName:lower()
    for _, frame in ipairs(container:GetChildren()) do
        if frame:IsA("Frame") then
            local nameMatch = frame.Name:lower() == lower
            local titleAttr = frame:GetAttribute("Title")
            local titleMatch = titleAttr and tostring(titleAttr):lower() == lower
            if nameMatch or titleMatch then
                local durAttr = frame:GetAttribute("TooltipDur")
                if durAttr then return tonumber(durAttr) or 0 end
                local durLabel = frame:FindFirstChild("Duration")
                if durLabel and durLabel:IsA("TextLabel") then
                    return tonumber(durLabel.Text) or 0
                end
                return 1
            end
        end
    end
    return 0
end

local function FighterHasStatus(fighter, name)
    return GetStatusDuration(fighter, name) > 0
end

local function EnemyStatusDur(ctx, name)
    return GetStatusDuration(GetEnemyFighter(ctx), name)
end

local function IsPlayerIncapacitated(ctx)
    local f = GetPlayerFighter(ctx)
    return FighterHasStatus(f,"Stun") or FighterHasStatus(f,"Freeze")
end

local function IsConfused(ctx)
    return FighterHasStatus(GetPlayerFighter(ctx),"Confusion")
end

local function EnemyHasStatus(ctx, name)    return FighterHasStatus(GetEnemyFighter(ctx), name)               end
