local function ShowPriorityBuilder(title, moves, currentPrio, onSave)
    local w = C_W - 16; local h = 295
    OpenPopup(w, h)
    local yOff = AddPopupHeader(title)

    local ordered = {}
    for _, mn in ipairs(currentPrio or {}) do
        for _, m in ipairs(moves) do
            if m.name == mn then table.insert(ordered, m); break end
        end
    end

    local function GetPool()
        local pool = {}
        for _, m in ipairs(moves) do
            local found = false
            for _, om in ipairs(ordered) do
                if om.name == m.name then found = true; break end
            end
            if not found then table.insert(pool, m) end
        end
        return pool
    end

    local avlL = MkLabel(PopupFrame, "Available", 9, T_SUB, Enum.Font.GothamBold)
    avlL.Size = UDim2.new(0.5,-10,0,14); avlL.Position = UDim2.new(0,9,0,yOff); avlL.ZIndex = 52
    local prioL = MkLabel(PopupFrame, "Priority", 9, T_SUB, Enum.Font.GothamBold)
    prioL.Size = UDim2.new(0.5,-10,0,14); prioL.Position = UDim2.new(0.5,1,0,yOff); prioL.ZIndex = 52
    yOff = yOff + 16

    local lH = 158

    local poolF = Instance.new("Frame", PopupFrame)
    poolF.Size = UDim2.new(0.5,-10,0,lH); poolF.Position = UDim2.new(0,9,0,yOff)
    poolF.BackgroundColor3 = BG_CARD; poolF.BorderSizePixel = 0
    poolF.ClipsDescendants = true; poolF.ZIndex = 52; MkCorner(poolF,6); MkStroke(poolF,COL_DIV,1)
    local pLL = Instance.new("UIListLayout", poolF)
    pLL.SortOrder = Enum.SortOrder.LayoutOrder; pLL.Padding = UDim.new(0,2)
    local pPd = Instance.new("UIPadding", poolF)
    pPd.PaddingTop = UDim.new(0,3); pPd.PaddingLeft = UDim.new(0,3); pPd.PaddingRight = UDim.new(0,3)

    local queueF = Instance.new("Frame", PopupFrame)
    queueF.Size = UDim2.new(0.5,-10,0,lH); queueF.Position = UDim2.new(0.5,1,0,yOff)
    queueF.BackgroundColor3 = BG_CARD; queueF.BorderSizePixel = 0
    queueF.ClipsDescendants = true; queueF.ZIndex = 52; MkCorner(queueF,6); MkStroke(queueF,COL_DIV,1)
    local qLL = Instance.new("UIListLayout", queueF)
    qLL.SortOrder = Enum.SortOrder.LayoutOrder; qLL.Padding = UDim.new(0,2)
    local qPd = Instance.new("UIPadding", queueF)
    qPd.PaddingTop = UDim.new(0,3); qPd.PaddingLeft = UDim.new(0,3); qPd.PaddingRight = UDim.new(0,3)

    local RebuildPool
    local RebuildQueue

    RebuildQueue = function()
        for _, c in ipairs(queueF:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
        end
        for i, m in ipairs(ordered) do
            local row = Instance.new("Frame", queueF)
            row.Size = UDim2.new(1,0,0,24); row.BackgroundColor3 = BG_SECOND
            row.BorderSizePixel = 0; row.LayoutOrder = i; row.ZIndex = 53; MkCorner(row,4)
            local num = MkLabel(row, i..".", 9, COL_ACCENT, Enum.Font.GothamBold)
            num.Size = UDim2.new(0,16,1,0); num.Position = UDim2.new(0,3,0,0); num.ZIndex = 54
            local nm = MkLabel(row, m.name, 9, T_PRIM, Enum.Font.GothamMedium)
            nm.Size = UDim2.new(1,-38,1,0); nm.Position = UDim2.new(0,20,0,0)
            nm.TextTruncate = Enum.TextTruncate.AtEnd; nm.ZIndex = 54
            local rmBtn = MkBtn(row, "X", Color3.fromRGB(45,12,12), COL_RED, 8)
            rmBtn.Size = UDim2.new(0,16,0,16); rmBtn.Position = UDim2.new(1,-19,0.5,-8); rmBtn.ZIndex = 54
            local ci = i
            rmBtn.MouseButton1Click:Connect(function()
                table.remove(ordered, ci); RebuildPool(); RebuildQueue()
            end)
        end
    end

    RebuildPool = function()
        for _, c in ipairs(poolF:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local pool = GetPool()
        for pi, pm in ipairs(pool) do
            local pb = MkBtn(poolF, pm.name, BG_SECOND, T_PRIM, 9)
            pb.Size = UDim2.new(1,0,0,24); pb.LayoutOrder = pi; pb.ZIndex = 53
            pb.TextTruncate = Enum.TextTruncate.AtEnd
            local cap = pm
            pb.MouseButton1Click:Connect(function()
                table.insert(ordered, cap); pb:Destroy(); RebuildQueue()
            end)
        end
    end

    RebuildPool(); RebuildQueue()

    local saveBtn = MkBtn(PopupFrame, "Save Priority", COL_ACCS, T_PRIM, 11)
    saveBtn.Size = UDim2.new(1,-18,0,28); saveBtn.Position = UDim2.new(0,9,0,yOff+lH+6)
    saveBtn.ZIndex = 52; MkStroke(saveBtn, COL_ACCENT, 1)
    saveBtn.MouseButton1Click:Connect(function()
        local result = {}
        for _, m in ipairs(ordered) do table.insert(result, m.name) end
        onSave(result)
    end)
end

