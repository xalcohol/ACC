local function GetEquippedStandName()
    local lbl = InvPath("StandTabContent","StandInfoCard","StandRow","Label")
    if not lbl then return "" end
    return (ParseLabel(lbl.Text or ""))
end

local function GetEquippedStyleName()
    local lbl = InvPath("PlayerTabContent","PlayerInfoCard","StyleRow","Label")
    if not lbl then return "" end
    return (ParseLabel(lbl.Text or ""))
end

local function GetEquippedStandDisplay()
    local lbl = InvPath("StandTabContent","StandInfoCard","StandRow","Label")
    return lbl and FormatDisplay(lbl.Text or "") or "---"
end

local function GetEquippedStyleDisplay()
    local lbl = InvPath("PlayerTabContent","PlayerInfoCard","StyleRow","Label")
    return lbl and FormatDisplay(lbl.Text or "") or "---"
end

local function ScanStandStorage()
    local container = InvPath("StandTabContent","StandMidRow","StandStorageCard","StorageContainer")
    if not container then return {} end
    local results = {}; local slotNum = 0
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum += 1
            local nl = child:FindFirstChild("NameLabel") or child:FindFirstChildWhichIsA("TextLabel")
            local raw = nl and (nl.Text or "") or ""
            local base, _ = ParseLabel(raw)
            table.insert(results, { slotNum=slotNum, swapArg=slotNum, displayName=FormatDisplay(raw), baseName=base })
        end
    end
    return results
end

local function ScanStyleStorage()
    local container = InvPath("PlayerTabContent","PlayerMidRow","StyleStorageCard","StorageContainer")
    if not container then return {} end
    local results = {}; local slotNum = 0
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum += 1
            local nl = child:FindFirstChild("NameLabel") or child:FindFirstChildWhichIsA("TextLabel")
            local raw = nl and (nl.Text or "") or ""
            local base, _ = ParseLabel(raw)
            table.insert(results, { slotNum=slotNum, swapArg=slotNum, displayName=FormatDisplay(raw), baseName=base })
        end
    end
    return results
end

local function FindStandSlot(name)
    for _, s in ipairs(ScanStandStorage()) do
        if s.baseName:lower() == name:lower() then return s.swapArg end
    end
end

local function FindStyleSlot(name)
    for _, s in ipairs(ScanStyleStorage()) do
        if s.baseName:lower() == name:lower() then return s.swapArg end
    end
end

local function EnsureStand(name)
    if not name or name == "" then return end
    if GetEquippedStandName():lower() == name:lower() then return end
    local slot = FindStandSlot(name); if not slot then return end
    SwapStand(slot)
    local t = 0
    while t < 5 do task.wait(0.3); t+=0.3
        if GetEquippedStandName():lower() == name:lower() then return end
    end
end

local function EnsureStyle(name)
    if not name or name == "" then return end
    if GetEquippedStyleName():lower() == name:lower() then return end
    local slot = FindStyleSlot(name); if not slot then return end
    SwapStyle(slot)
    local t = 0
    while t < 5 do task.wait(0.3); t+=0.3
        if GetEquippedStyleName():lower() == name:lower() then return end
    end
end

