            local ci=i
            rmBtn.MouseButton1Click:Connect(function()
                table.remove(ordered,ci); RebuildQueue()
                for _,c2 in ipairs(poolF:GetChildren()) do if c2:IsA("TextButton") then c2:Destroy() end end
                for pi,pm in ipairs(GetPool()) do
                    local pb=Btn(poolF,pm.name,C.bgSecond,C.tPrim,9); pb.Size=UDim2.new(1,0,0,24); pb.LayoutOrder=pi; pb.ZIndex=53; pb.TextTruncate=Enum.TextTruncate.AtEnd
                    local cap=pm; pb.MouseButton1Click:Connect(function() table.insert(ordered,cap); pb:Destroy(); RebuildQueue() end)
                end
            end)
        end
    end

    local function BuildPool()
        for _,c in ipairs(poolF:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for i,m in ipairs(GetPool()) do
            local pb=Btn(poolF,m.name,C.bgSecond,C.tPrim,9); pb.Size=UDim2.new(1,0,0,24); pb.LayoutOrder=i; pb.ZIndex=53; pb.TextTruncate=Enum.TextTruncate.AtEnd
            local cap=m; pb.MouseButton1Click:Connect(function() table.insert(ordered,cap); pb:Destroy(); RebuildQueue() end)
        end
    end

    BuildPool(); RebuildQueue()

    local saveBtn=Btn(PopupFrame,"Save Priority",C.accentS,C.tPrim,11)
    saveBtn.Size=UDim2.new(1,-18,0,28); saveBtn.Position=UDim2.new(0,9,0,yOff+lH+6); saveBtn.ZIndex=52; Stroke(saveBtn,C.accent,1)
    saveBtn.MouseButton1Click:Connect(function()
        local result={}; for _,m in ipairs(ordered) do table.insert(result,m.name) end; onSave(result)
    end)
end

