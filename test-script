-- [[ LOADOUT DETECTION ]] -- unchanged from Proto A
-- ================================================================
local function DetectLoadoutFromInventory()
    local styleNode = SafeGet(PlayerGui, table.unpack(INV_STYLE_PATH))
    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
    if styleNode then
        local t = styleNode.Text or ""
        if     t:find("ULTIMATE LIFEFORM") then CurrentStyle = "ULF"
        elseif t:find("SHRINE")            then CurrentStyle = "Shrine"
        else                                    CurrentStyle = "Unknown" end
    end
    if standNode then
        CurrentStand = FormatStandLabel(standNode.Text or "")
    end
    UpdateLoadoutLabels()
end

local function ConfirmLoadoutInCombat(ctx)
    local area = SafeGet(ctx.Root(), "AbilitiesArea")
    if not area then return end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = btn.Name:match("^(.-)%s*%(%d+%)%s*$") or btn.Name
            for _, data in pairs(LOADOUT.Style) do
                if base == data.signature then CurrentStyle = data.label end
            end
            for _, data in pairs(LOADOUT.Stand) do
                if base == data.signature then
                    local standNode = SafeGet(PlayerGui, table.unpack(INV_STAND_PATH))
                    if standNode then
                        CurrentStand = FormatStandLabel(standNode.Text or "")
                    else
                        CurrentStand = data.label
                    end
                end
            end
        end
    end
    UpdateLoadoutLabels()
end

