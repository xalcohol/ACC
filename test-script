local function ShowPriorityBuilder(title,moves,currentPrio,onSave)
    local w=C_W-16; local h=295
    OpenPopup(w,h); local yOff=PopupHeader(title)
    local ordered={}
    for _,mn in ipairs(currentPrio or {}) do
        for _,m in ipairs(moves) do if m.name==mn then table.insert(ordered,m); break end end
    end
    local function GetPool()
        local pool={}
        for _,m in ipairs(moves) do
            local f=false; for _,om in ipairs(ordered) do if om.name==m.name then f=true; break end end
            if not f then table.insert(pool,m) end
        end
        return pool
    end

    local colY=yOff
    local avl=Lbl(PopupFrame,"Available",9,C.tSub,Enum.Font.GothamBold); avl.Size=UDim2.new(0.5,-10,0,14); avl.Position=UDim2.new(0,9,0,colY); avl.ZIndex=52
