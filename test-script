local function SafeGet(root, ...)
    local cur = root
    for _, n in ipairs({...}) do
        if not cur then return nil end
        cur = cur:FindFirstChild(n)
    end
    return cur
end

local CONTENT_BASE = {"JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame","MainPanel","InnerContent","ContentArea"}
local function GamePath(...) return SafeGet(PlayerGui, table.unpack(CONTENT_BASE), ...) end
local function InvPath(...)  return SafeGet(PlayerGui,"JJBIMenu","MainFrame","ContentContainer","InventoryFrame","MainPanel","InnerContent","TabContainer",...) end

-- ================================================================
-- [[ TEXT FORMATTING ]]
-- ================================================================
local SMALL = {of=true,the=true,a=true,an=true,and=true,["in"]=true,to=true}
local function ProperCase(str)
    local words = {}
    for w in str:lower():gmatch("%S+") do
        if #words == 0 or not SMALL[w] then w = w:sub(1,1):upper()..w:sub(2) end
        table.insert(words, w)
    end
    return table.concat(words, " ")
end

local function StripRich(text)
    return (text or ""):gsub("<[^>]+>",""):gsub("%s+"," "):match("^%s*(.-)%s*$")
end

local function ParseLabel(raw)
    local clean = StripRich(raw)
    clean = clean:match("^%u[%u%s]*:%s*(.+)$") or clean
    local traits = {}
    for t in clean:gmatch("%[([^%]]+)%]") do table.insert(traits, ProperCase(t)) end
    local base = clean:gsub("%s*%[.-%]",""):gsub("%s*&%s*",""):match("^%s*(.-)%s*$")
    return ProperCase(base), traits
end

local function FormatDisplay(raw)
    local base, traits = ParseLabel(raw)
    if #traits == 0 then return base end
    local parts = {}
    for _, t in ipairs(traits) do table.insert(parts, "["..t.."]") end
    return base.." "..table.concat(parts," & ")
end

