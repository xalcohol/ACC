-- ╔══════════════════════════════╗
-- ║         CORE LOGIC           ║
-- ╚══════════════════════════════╝

local function getChestCount(chestName)
	local ok, result = pcall(function()
		local numberLabel = PlayerGui
			:WaitForChild("Inventory")
			:WaitForChild("CanvasGroup")
			:WaitForChild("backpack_frame")
			:WaitForChild("enlarging_frame")
			:WaitForChild("holder")
			:WaitForChild(chestName)
			:WaitForChild("Holder")
			:WaitForChild("Holder")
			:WaitForChild("Number")
		return numberLabel.Text
	end)
	if not ok then return nil end
	return tonumber(tostring(result):match("(%d+)x?"))
end

local function fireDestroy(name, amount)
	local args = {
		{
			Name = name,
			Amount = amount
		}
	}
	ReplicatedStorage
		:WaitForChild("requests")
		:WaitForChild("general")
		:WaitForChild("DestroyItem")
		:FireServer(unpack(args))
end

local function setRunning(state)
	running = state

	if running then
		button.Text = "STOP"
		button.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
		statusLabel.Text = "Status: Running"
		statusLabel.TextColor3 = Color3.fromRGB(100, 220, 100)

		loopThread = task.spawn(function()
			while running do
				local common = getChestCount("Common Chest")
				if common and common > 0 then
					fireDestroy("Common Chest", common)
				end

				local rare = getChestCount("Rare Chest")
				if rare and rare > 0 then
					fireDestroy("Rare Chest", rare)
				end

				task.wait(INTERVAL)
			end
		end)
	else
		button.Text = "START"
		button.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
		statusLabel.Text = "Status: Idle"
		statusLabel.TextColor3 = Color3.fromRGB(160, 160, 160)

		if loopThread then
			task.cancel(loopThread)
			loopThread = nil
		end
	end
end

button.MouseButton1Click:Connect(function()
	setRunning(not running)
end)

killButton.MouseButton1Click:Connect(function()
	if loopThread then
		task.cancel(loopThread)
	end
	screenGui:Destroy()
end)

-- Auto-start on launch
setRunning(true)
