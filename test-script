		BackgroundColor3 = looping and Color3.fromRGB(90, 25, 35) or Color3.fromRGB(60, 50, 100)
	}):Play()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == TOGGLE_KEY then
		toggle()
	elseif input.KeyCode == DESTROY_KEY then
		destroyAll()
	end
end)

updateModeButtons()
print("[TeleportLoop] Loaded — K: toggle | ': destroy | select C / J / BOTH")
