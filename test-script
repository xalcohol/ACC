-- ================================================================
-- [[ AUTO STORY LOOP ]] -- unchanged from Proto A
-- ================================================================
local function RunStoryLoop()
    EnforceStoryLoadout()
    TryFleeFromDungeon()
    task.wait(0.5)

    if IsInStoryBattle() then
        RunStoryBattleLoop(function() return StoryEnabled end)
        task.wait(ACTION_CD)
    end

    if PrestigeEnabled then
        FirePrestige(); task.wait(ACTION_CD)
    end

    task.spawn(RunWorldBossScanner)

    while StoryEnabled and not ScriptKilled do
        if WorldBossPriority then
            if IsInStoryBattle() then
                RunStoryBattleLoop(function() return StoryEnabled end)
                task.wait(ACTION_CD)
            end
            RunWorldBossFight(); task.wait(ACTION_CD)

        elseif PrestigeEnabled and IsBokuNoRhythm() then
            FirePrestige(); task.wait(ACTION_CD)

        else
            CombatAction:FireServer("EngageStory"); task.wait(ACTION_CD)
            RunStoryBattleLoop(function() return StoryEnabled end)
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

-- ================================================================
-- [[ AUTO DUNGEON LOOP ]]
-- B addition: daily mode floor check layered in
-- ================================================================
local function RunDungeonLoop()
    EnforceDungeonLoadout()

    while DungeonEnabled and not ScriptKilled do
        -- B: daily mode floor check
        if CFG.dailyModeOn and CFG.dailyFloor then
            local floor = 0
            local lbl = SafeGet(PlayerGui,
                "JJBIMenu","MainFrame","ContentContainer","SingleplayerFrame",
                "MainPanel","InnerContent","ContentArea","DungeonFrame",
                "CombatMainFrame","WaveLabel")
            if lbl then floor = tonumber((lbl.Text or ""):match("Floor%s+(%d+)")) or 0 end
            if floor > CFG.dailyFloor then
                TryFleeFromDungeon(); task.wait(0.5)
                DungeonEnabled = false; StoryEnabled = true
                task.spawn(RunStoryLoop); return
            end
        end

        if not IsInDungeonBattle() then
            StartDungeon(); task.wait(ACTION_CD)
            local waited = 0
            while not IsInDungeonBattle() and waited < 5 do
                task.wait(0.2); waited = waited + 0.2
            end
        end
        if IsInDungeonBattle() then
            RunDungeonBattleLoop(function() return DungeonEnabled end)
        end
        task.wait(ACTION_CD)
    end
end

