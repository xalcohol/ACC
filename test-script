-- ─── GUI STATE ──────────────────────────────────────────────────────────────

local ON_COL  = Color3.fromRGB(60, 50, 110)
local ON_TXT  = Color3.fromRGB(210, 200, 255)
local OFF_COL = Color3.fromRGB(30, 30, 42)
local OFF_TXT = Color3.fromRGB(100, 100, 130)

local modeBtns = { C = btnC, J = btnJ, BOTH = btnBoth }

local function updateModeButtons()
	for m, btn in pairs(modeBtns) do
		if m == mode then
			btn.BackgroundColor3 = ON_COL
			btn.TextColor3 = ON_TXT
		else
			btn.BackgroundColor3 = OFF_COL
			btn.TextColor3 = OFF_TXT
		end
	end
end

local function setGuiActive(active)
	if active then
		statusLabel.Text = "● RUNNING  [" .. mode .. "]"
		statusLabel.TextColor3 = Color3.fromRGB(80, 220, 130)
		button.Text = "STOP  [K]"
		button.BackgroundColor3 = Color3.fromRGB(90, 25, 35)
		button.TextColor3 = Color3.fromRGB(255, 160, 160)
		btnStroke.Color = Color3.fromRGB(200, 60, 75)
		frameStroke.Color = Color3.fromRGB(80, 200, 110)
	else
		statusLabel.Text = "● IDLE"
		statusLabel.TextColor3 = Color3.fromRGB(120, 120, 150)
		button.Text = "START  [K]"
		button.BackgroundColor3 = Color3.fromRGB(60, 50, 100)
		button.TextColor3 = Color3.fromRGB(210, 200, 255)
		btnStroke.Color = Color3.fromRGB(100, 85, 180)
		frameStroke.Color = Color3.fromRGB(80, 70, 130)
	end
end

-- ─── DESTROY ────────────────────────────────────────────────────────────────

local destroyed = false

local function destroyAll()
	if destroyed then return end
	destroyed = true
	looping = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	if screenGui and screenGui.Parent then
		screenGui:Destroy()
	end
	script:Destroy()
	print("[TeleportLoop] Destroyed")
end

-- ─── LOGIC ──────────────────────────────────────────────────────────────────

local function getHRP()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("HumanoidRootPart")
end

local function pressKey(key)
	local ok, VIM = pcall(function()
		return game:GetService("VirtualInputManager")
	end)
	if ok and VIM then
		VIM:SendKeyEvent(true, key, false, game)
		task.wait(0.05)
		VIM:SendKeyEvent(false, key, false, game)
	else
		warn("[TeleportLoop] VirtualInputManager unavailable")
	end
end

-- Mode C: TP loc1 → press C → 2s → TP loc2 → 5s → repeat
local function runLoopC()
	while looping do
		local hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame1
		print("[TeleportLoop][C] Teleported to Location 1")

		task.wait(0.3)
		if not looping then break end

		pressKey(Enum.KeyCode.C)
		print("[TeleportLoop][C] Pressed C")

		task.wait(2)
		if not looping then break end

		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame2
		print("[TeleportLoop][C] Teleported to Location 2")

		task.wait(5)
	end
	print("[TeleportLoop][C] Loop ended")
end

-- Mode J: TP loc1 → press J → 1s → TP loc2 → 20s → repeat
local function runLoopJ()
	while looping do
		local hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame1
		print("[TeleportLoop][J] Teleported to Location 1")

		task.wait(0.3)
		if not looping then break end

		pressKey(Enum.KeyCode.J)
		print("[TeleportLoop][J] Pressed J")

		task.wait(1)
		if not looping then break end

		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame2
		print("[TeleportLoop][J] Teleported to Location 2")

		task.wait(20)
	end
	print("[TeleportLoop][J] Loop ended")
end

-- Mode BOTH:
--   TP loc1 → J → 1s → TP loc2 → 7s
--   TP loc1 → C → 2s → TP loc2 → 5s
--   TP loc1 → C → 2s → TP loc2 → 5s → repeat
local function runLoopBoth()
	while looping do
		local hrp

		-- J round
		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame1
		print("[TeleportLoop][BOTH] Teleported to Location 1 (J)")

		task.wait(0.3)
		if not looping then break end

		pressKey(Enum.KeyCode.J)
		print("[TeleportLoop][BOTH] Pressed J")

		task.wait(1)
		if not looping then break end

		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame2
		print("[TeleportLoop][BOTH] Teleported to Location 2 (after J)")

		task.wait(7)
		if not looping then break end

		-- C round 1
		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame1
		print("[TeleportLoop][BOTH] Teleported to Location 1 (C #1)")

		task.wait(0.3)
		if not looping then break end

		pressKey(Enum.KeyCode.C)
		print("[TeleportLoop][BOTH] Pressed C (#1)")

		task.wait(2)
		if not looping then break end

		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame2
		print("[TeleportLoop][BOTH] Teleported to Location 2 (after C #1)")

		task.wait(5)
		if not looping then break end

		-- C round 2
		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame1
		print("[TeleportLoop][BOTH] Teleported to Location 1 (C #2)")

		task.wait(0.3)
		if not looping then break end

		pressKey(Enum.KeyCode.C)
		print("[TeleportLoop][BOTH] Pressed C (#2)")

		task.wait(2)
		if not looping then break end

		hrp = getHRP()
		if not hrp then break end
		hrp.CFrame = CFrame2
		print("[TeleportLoop][BOTH] Teleported to Location 2 (after C #2)")

		task.wait(5)
	end
	print("[TeleportLoop][BOTH] Loop ended")
end

local function startLoop()
	if looping then return end
	looping = true
	setGuiActive(true)
	if mode == "C" then
		loopThread = task.spawn(runLoopC)
	elseif mode == "J" then
		loopThread = task.spawn(runLoopJ)
	else
		loopThread = task.spawn(runLoopBoth)
	end
	print("[TeleportLoop] Started — Mode:", mode)
end

local function stopLoop()
	if not looping then return end
	looping = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	setGuiActive(false)
	print("[TeleportLoop] Stopped")
end

local function toggle()
	if looping then stopLoop() else startLoop() end
end

