        l.Size = UDim2.new(1,0,1,0); l.Position = UDim2.new(0,0,0,0)
    end
end
local function MkOverlay(parent)
    local ov = Instance.new("Frame", parent)
    ov.Size = UDim2.new(1,0,1,0); ov.BackgroundColor3 = COL_BLACK
    ov.BackgroundTransparency = 0.55; ov.BorderSizePixel = 0
    ov.ZIndex = parent.ZIndex + 5; ov.Visible = false; MkCorner(ov, 6)
    return ov
end
local function ApplyHover(btn, n, h)
    btn.MouseEnter:Connect(function()
        if btn.BackgroundColor3 == n then btn.BackgroundColor3 = h end
    end)
    btn.MouseLeave:Connect(function()
        if btn.BackgroundColor3 == h then btn.BackgroundColor3 = n end
    end)
end
local function ApplyDisabledOverlay(btn)
    if btn:FindFirstChild("DisabledOverlay") then return end
    local overlay = Instance.new("Frame")
    overlay.Name = "DisabledOverlay"; overlay.Size = UDim2.new(1,0,1,0)
    overlay.BackgroundColor3 = COL_BLACK; overlay.BackgroundTransparency = 0.45
    overlay.BorderSizePixel = 0; overlay.ZIndex = btn.ZIndex + 1
    overlay.Parent = btn; MkCorner(overlay, 6)
end
local function RemoveDisabledOverlay(btn)
    local o = btn:FindFirstChild("DisabledOverlay")
    if o then o:Destroy() end
end
local function LockButton(btn)   btn.Active = false; ApplyDisabledOverlay(btn) end
local function UnlockButton(btn) btn.Active = true;  RemoveDisabledOverlay(btn) end

