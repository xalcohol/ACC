        ClosePopup(); SetStatus("Daily: floor "..floor,C.green)
        task.delay(2,function() if not DungeonEnabled then SetStatus("Idle") end end)
        if DungeonEnabled then DungeonEnabled=false; task.wait(0.2); DungeonEnabled=true; task.spawn(RunDungeonLoop) end
    end)
end

