-- TeleportLoop LocalScript
-- Toggle with K or the on-screen button

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local TOGGLE_KEY = Enum.KeyCode.K

-- Location 1 (start/return point)
local CFrame1 = CFrame.new(
	57.7528305, 0.578745723, 1820.71851,
	0.307113975, -4.71410182e-08, 0.951672733,
	-1.7533468e-08, 1, 5.5193123e-08,
	-0.951672733, -3.36367023e-08, 0.307113975
)

-- Location 2 (destination after pressing C)
local CFrame2 = CFrame.new(
	-1880.58508, 8.5140295, -739.799622,
	0.986630619, -4.39580568e-08, -0.16297254,
	4.29249845e-08, 1, -9.86027615e-09,
	0.16297254, 2.73285661e-09, 0.986630619
)

local looping = false
local loopThread = nil
local player = Players.LocalPlayer

-- ─── GUI ────────────────────────────────────────────────────────────────────

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TeleportLoopGui"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Draggable container
local frame = Instance.new("Frame")
frame.Name = "MainFrame"
frame.Size = UDim2.new(0, 200, 0, 80)
frame.Position = UDim2.new(0, 20, 0.5, -40)
frame.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(60, 60, 75)
stroke.Thickness = 1.2
stroke.Parent = frame

-- Title bar
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 26)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "TP LOOP"
title.TextColor3 = Color3.fromRGB(160, 155, 200)
title.TextSize = 11
title.Font = Enum.Font.GothamBold
title.LetterSpacing = 4
title.Parent = frame

-- Status label
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -16, 0, 16)
statusLabel.Position = UDim2.new(0, 8, 0, 26)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "● IDLE"
statusLabel.TextColor3 = Color3.fromRGB(120, 120, 140)
statusLabel.TextSize = 11
statusLabel.Font = Enum.Font.Gotham
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Parent = frame

-- Toggle button
local button = Instance.new("TextButton")
button.Size = UDim2.new(1, -16, 0, 26)
button.Position = UDim2.new(0, 8, 0, 46)
button.BackgroundColor3 = Color3.fromRGB(55, 50, 90)
button.BorderSizePixel = 0
button.Text = "START  [K]"
button.TextColor3 = Color3.fromRGB(200, 195, 255)
button.TextSize = 12
button.Font = Enum.Font.GothamBold
button.Parent = frame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 6)
btnCorner.Parent = button

local btnStroke = Instance.new("UIStroke")
btnStroke.Color = Color3.fromRGB(90, 80, 160)
btnStroke.Thickness = 1
btnStroke.Parent = button

-- Pulsing status dot
local dot = Instance.new("Frame")
dot.Size = UDim2.new(0, 7, 0, 7)
dot.Position = UDim2.new(0, 8, 0, 30)
dot.BackgroundColor3 = Color3.fromRGB(120, 120, 140)
dot.BorderSizePixel = 0
dot.Parent = frame

local dotCorner = Instance.new("UICorner")
dotCorner.CornerRadius = UDim.new(1, 0)
dotCorner.Parent = dot

local pulseTween = TweenService:Create(dot,
	TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
	{ BackgroundColor3 = Color3.fromRGB(80, 220, 130) }
)

local function setGuiActive(active)
	if active then
		statusLabel.Text = "● RUNNING"
		statusLabel.TextColor3 = Color3.fromRGB(80, 220, 130)
		button.Text = "STOP  [K]"
		button.BackgroundColor3 = Color3.fromRGB(80, 30, 40)
		button.TextColor3 = Color3.fromRGB(255, 160, 160)
		btnStroke.Color = Color3.fromRGB(180, 60, 70)
		dot.BackgroundColor3 = Color3.fromRGB(80, 220, 130)
		pulseTween:Play()
	else
		statusLabel.Text = "● IDLE"
		statusLabel.TextColor3 = Color3.fromRGB(120, 120, 140)
		button.Text = "START  [K]"
		button.BackgroundColor3 = Color3.fromRGB(55, 50, 90)
		button.TextColor3 = Color3.fromRGB(200, 195, 255)
		btnStroke.Color = Color3.fromRGB(90, 80, 160)
		dot.BackgroundColor3 = Color3.fromRGB(120, 120, 140)
		pulseTween:Cancel()
	end
end

-- ─── LOGIC ──────────────────────────────────────────────────────────────────

local function getCharacter()
	return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
	local char = getCharacter()
	return char:WaitForChild("HumanoidRootPart")
end

local function pressC()
	local VIM = game:GetService("VirtualInputManager")
	VIM:SendKeyEvent(true,  Enum.KeyCode.C, false, game)
	task.wait(0.05)
	VIM:SendKeyEvent(false, Enum.KeyCode.C, false, game)
end

local function runLoop()
	while looping do
		-- Step 1: TP to Location 1
		local hrp = getHRP()
		hrp.CFrame = CFrame1

		task.wait(0.2)

		-- Step 2: Press C
		pressC()

		-- Step 3: Wait 3 seconds, TP to Location 2
		task.wait(3)
		if not looping then break end

		hrp = getHRP()
		hrp.CFrame = CFrame2

		-- Step 4: Wait 4 seconds, loop back
		task.wait(4)
	end
end

local function startLoop()
	looping = true
	loopThread = task.spawn(runLoop)
	setGuiActive(true)
	print("[TeleportLoop] Started")
end

local function stopLoop()
	looping = false
	if loopThread then
		task.cancel(loopThread)
		loopThread = nil
	end
	setGuiActive(false)
	print("[TeleportLoop] Stopped")
end

local function toggle()
	if looping then stopLoop() else startLoop() end
end

-- ─── INPUT ──────────────────────────────────────────────────────────────────

button.MouseButton1Click:Connect(toggle)

button.MouseEnter:Connect(function()
	TweenService:Create(button, TweenInfo.new(0.15), {
		BackgroundColor3 = looping
			and Color3.fromRGB(110, 40, 50)
			or  Color3.fromRGB(75, 68, 120)
	}):Play()
end)

button.MouseLeave:Connect(function()
	TweenService:Create(button, TweenInfo.new(0.15), {
		BackgroundColor3 = looping
			and Color3.fromRGB(80, 30, 40)
			or  Color3.fromRGB(55, 50, 90)
	}):Play()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == TOGGLE_KEY then toggle() end
end)

print("[TeleportLoop] Loaded — press K or click the button to toggle")
