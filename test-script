-- ================================================================
-- [[ STORY LOOP ]]
-- ================================================================
local StoryEnabled = false
local PrestigeMode = CFG.prestigeEnabled

local function IsBokuNoRhythm()
    local sf = GamePath("StoryFrame"); if not sf then return false end
    local btn = SafeGet(sf,"ButtonContainer","StoryEncounterBtn"); if not btn then return false end
    for _, obj in ipairs(btn:GetDescendants()) do
        if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and (obj.Text or ""):find("Boku no Rhythm") then return true end
    end
    return false
end

local function RunStoryLoop()
    EnsureStand(CFG.storyStandName)
    EnsureStyle(LOCKED_STYLE)
    FleeDungeon()
    task.wait(0.5)
    task.spawn(function() pcall(EnsureTraining) end)
    task.spawn(RunWorldBossScanner, function() return StoryEnabled end)

    if IsInStoryBattle() then
        task.wait(0.3)
        while StoryEnabled and not ScriptKilled and IsInStoryBattle() do
            RunStoryCombatTick(); task.wait(0.2)
        end
        if WorldBossPriority then RunWorldBossFight() end
    end

    while StoryEnabled and not ScriptKilled do
        if WorldBossPriority then
            RunWorldBossFight(); task.wait(0.3); continue
        end
        if PrestigeMode and IsBokuNoRhythm() then
            FirePrestige(); task.wait(0.5); continue
        end
        EngageStory(); task.wait(0.3)
        while StoryEnabled and not ScriptKilled and IsInStoryBattle() do
            RunStoryCombatTick(); task.wait(0.2)
        end
        task.wait(0.2)
    end
end

-- ================================================================
-- [[ DUNGEON LOOP ]]
-- ================================================================
local DungeonEnabled = false

local function RunDungeonLoop()
    if IsInStoryBattle() then FleeStory(); task.wait(1) end
    EnsureStand(CFG.dungeonStandName)
    EnsureStyle(LOCKED_STYLE)

    while DungeonEnabled and not ScriptKilled do
        if CFG.dailyModeOn and CFG.dailyFloor and GetDungeonFloor() > CFG.dailyFloor then
            FleeDungeon(); task.wait(0.5)
            DungeonEnabled = false; StoryEnabled = true
            task.spawn(RunStoryLoop); return
        end

        if not IsInDungeonBattle() then
            StartDungeon(); task.wait(0.5)
            local t = 0
            while not IsInDungeonBattle() and t < 5 do task.wait(0.3); t+=0.3 end
        end

        while DungeonEnabled and not ScriptKilled and IsInDungeonBattle() do
            if CFG.dailyModeOn and CFG.dailyFloor and GetDungeonFloor() > CFG.dailyFloor then
                FleeDungeon(); task.wait(0.5)
                DungeonEnabled = false; StoryEnabled = true
                task.spawn(RunStoryLoop); return
            end
            RunDungeonCombatTick(); task.wait(0.2)
        end
        task.wait(0.2)
    end
end

