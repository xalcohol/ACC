            local nm=Lbl(row,m.name,9,C.tPrim,Enum.Font.GothamMedium); nm.Size=UDim2.new(1,-38,1,0); nm.Position=UDim2.new(0,20,0,0); nm.TextTruncate=Enum.TextTruncate.AtEnd; nm.ZIndex=54
