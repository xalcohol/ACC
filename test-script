local function SaveConfig()
    _G.JJBIConfigBSaved = {}
    for k, v in pairs(CFG) do
        if type(v) == "table" then
            local copy = {}
            for i = 1, #v do copy[i] = v[i] end
            _G.JJBIConfigBSaved[k] = copy
        else
            _G.JJBIConfigBSaved[k] = v
        end
    end
end

local function LoadConfig()
    if not _G.JJBIConfigBSaved then return false end
    for k, v in pairs(_G.JJBIConfigBSaved) do
        if type(v) == "table" then
            local copy = {}
            for i = 1, #v do copy[i] = v[i] end
            CFG[k] = copy
        else
            CFG[k] = v
        end
    end
    return true
end

