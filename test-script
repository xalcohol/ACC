local function IsInStoryBattle()
    local p = GamePath("StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player")
    local e = GamePath("StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy")
    return p ~= nil or e ~= nil
end

local function IsInDungeonBattle()
    local p = GamePath("DungeonFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player")
    local e = GamePath("DungeonFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy")
    return p ~= nil or e ~= nil
end

local function GetHP(mode)
    local p = {
        story   = {"StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","HpContainer","HpText"},
        dungeon = {"DungeonFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","HpContainer","HpText"},
        wb      = {"WorldBossFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","HpContainer","HpText"},
    }
    local node = GamePath(table.unpack(p[mode] or p.story))
    if not node then return 1,1,1.0 end
    local cur,max = (node.Text or ""):match("(%d+)%s*/%s*(%d+)")
    cur=tonumber(cur) or 1; max=tonumber(max) or 1
    return cur,max,(max>0 and cur/max or 1.0)
end

local function GetResources(mode)
    local node = mode == "dungeon"
        and GamePath("DungeonFrame","CombatMainFrame","ContentContainer","ResourceLabel")
        or  GamePath("StoryFrame","CombatMainFrame","ContentContainer","ResourceLabel")
    if not node then return 0,0 end
    local t = node.Text or ""
    return tonumber(t:match("ENERGY%s*:%s*(%d+)")) or 0,
           tonumber(t:match("STAMINA%s*:%s*(%d+)")) or 0
end

local function GetStatusDur(mode, who, statusName)
    local paths = {
        story   = { player={"StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","StatusContainer"},
                    enemy ={"StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy","InfoArea","StatusContainer"} },
        dungeon = { player={"DungeonFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","StatusContainer"},
                    enemy ={"DungeonFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy","InfoArea","StatusContainer"} },
        wb      = { player={"WorldBossFrame","CombatMainFrame","ContentContainer","HealthbarArea","AlliesContainer","Fighter_Player","InfoArea","StatusContainer"},
                    enemy ={"WorldBossFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy","InfoArea","StatusContainer"} },
    }
    local mp = paths[mode] or paths.story
    local container = GamePath(table.unpack(mp[who] or mp.player))
    if not container then return 0 end
    local lower = statusName:lower()
    for _, f in ipairs(container:GetChildren()) do
        if f:IsA("Frame") and f.Name:lower() == lower then
            return tonumber(f:GetAttribute("TooltipDur")) or 0
        end
    end
    return 0
end

local function HasStatus(mode, who, name) return GetStatusDur(mode,who,name) > 0 end

local function GetEnemyName()
    local lbl = GamePath("StoryFrame","CombatMainFrame","ContentContainer","HealthbarArea","EnemiesContainer","Fighter_Enemy","InfoArea","NameLabel")
    return lbl and (lbl.Text or "") or ""
end

local function GetDungeonFloor()
    local lbl = GamePath("DungeonFrame","CombatMainFrame","WaveLabel")
    if not lbl then return 0 end
    return tonumber((lbl.Text or ""):match("Floor%s+(%d+)")) or 0
end

local function CanUse(mode, moveName)
    local area
    if     mode == "dungeon" then area = GamePath("DungeonFrame","CombatMainFrame","ContentContainer","AbilitiesArea")
    elseif mode == "wb"      then area = GamePath("WorldBossFrame","CombatMainFrame","ContentContainer","AbilitiesArea")
    else                          area = GamePath("StoryFrame","CombatMainFrame","ContentContainer","AbilitiesArea") end
    if not area then return false end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = (btn.Name:match("^(.-)%s*%(") or btn.Name):match("^%s*(.-)%s*$")
            if base == moveName then return not btn.Name:match("%((%d+)%)") end
        end
    end
    return false
end

-- ================================================================
-- [[ GLOBAL COMBAT ENGINE ]]
-- ================================================================
local ENERGY_THRESHOLD  = 35
local STAMINA_THRESHOLD = 30
local HP_HEAL_THRESHOLD = 0.67
local healBlocked = {story=false, dungeon=false, wb=false}

local function GetFireFn(mode)
    if mode == "dungeon" then return FireDungeon end
    if mode == "wb"      then return FireWB end
    return FireStory
end

local function GlobalCombatRules(mode)
    local fire = GetFireFn(mode)

    -- 1. Confusion -> Rest
    if HasStatus(mode,"player","Confusion") then fire("Rest"); return true end

    -- 2. Stun/Freeze -> Normal Attack
    if HasStatus(mode,"player","Stun") or HasStatus(mode,"player","Freeze") then
        local sn = mode=="wb" and CFG.wbStandName or mode=="dungeon" and CFG.dungeonStandName or CFG.storyStandName
        local sd = sn and STAND_DATA[sn]
        fire(sd and sd.normal or "Infinite Rotation"); return true
    end

    -- 3. HP heal check
    local styleName = GetEquippedStyleName()
    local styleData = STYLE_DATA[styleName]
    if styleData and styleData.healMove then
        local _,_,hpPct = GetHP(mode)
        if hpPct < HP_HEAL_THRESHOLD then
            if CanUse(mode, styleData.healMove) then
                healBlocked[mode] = false
                fire(styleData.healMove); return true
            elseif not healBlocked[mode] then
                healBlocked[mode] = true
                if CanUse(mode,"Block") then fire("Block"); return true end
            end
        else
            healBlocked[mode] = false
        end
    end

    return false
end

local function ShouldRest(mode)
    local e,s = GetResources(mode)
    return e < ENERGY_THRESHOLD and s < STAMINA_THRESHOLD
end

local function ExecutePriority(mode, priorityList)
    if not priorityList or #priorityList == 0 then return false end
    local fire = GetFireFn(mode)
    local moveMap = {}
    local sn = mode=="wb" and CFG.wbStandName or mode=="dungeon" and CFG.dungeonStandName or CFG.storyStandName
    local styleName = mode=="wb" and CFG.wbStyleName or LOCKED_STYLE
    if sn and STAND_DATA[sn] then for _,m in ipairs(STAND_DATA[sn].moves) do moveMap[m.name]=m end end
    if styleName and STYLE_DATA[styleName] then for _,m in ipairs(STYLE_DATA[styleName].moves) do moveMap[m.name]=m end end

    for _, moveName in ipairs(priorityList) do
        if not CanUse(mode, moveName) then continue end
        local m = moveMap[moveName]; if not m then continue end
        local e,s = GetResources(mode)
        if m.cost=="energy"  and e < ENERGY_THRESHOLD  then continue end
        if m.cost=="stamina" and s < STAMINA_THRESHOLD then continue end
        local st = m.statusType
        if st=="confusion" then
            if HasStatus(mode,"enemy","ConfImmunity") or HasStatus(mode,"enemy","Confusion") then continue end
        elseif st=="stun" then
            if HasStatus(mode,"enemy","StunImmunity") or HasStatus(mode,"enemy","Stun") or HasStatus(mode,"enemy","Freeze") then continue end
        elseif st=="burn"   then if GetStatusDur(mode,"enemy","Burn")   > 1 then continue end
        elseif st=="bleed"  then if GetStatusDur(mode,"enemy","Bleed")  > 1 then continue end
        elseif st=="poison" then if GetStatusDur(mode,"enemy","Poison") > 1 then continue end
        end
        fire(moveName); return true
    end
    return false
end

-- ================================================================
-- [[ STORY COMBAT ENGINE ]]
-- ================================================================
local function RunStoryCombatTick()
    if GlobalCombatRules("story") then return end
    if ShouldRest("story") then FireStory("Rest"); return end
    local enemy = GetEnemyName()
    if enemy == "Enrico Pucci" and #CFG.pucciPriority > 0 then
        if ExecutePriority("story", CFG.pucciPriority) then return end
    end
    if enemy == "Tooru" and #CFG.tooruPriority > 0 then
        if ExecutePriority("story", CFG.tooruPriority) then return end
    end
    local sd = CFG.storyStandName and STAND_DATA[CFG.storyStandName]
    FireStory(sd and sd.normal or "Infinite Rotation")
end

-- ================================================================
-- [[ DUNGEON COMBAT ENGINE ]]
-- ================================================================
local function RunDungeonCombatTick()
    if GlobalCombatRules("dungeon") then return end
    if ShouldRest("dungeon") then FireDungeon("Rest"); return end
    if #CFG.dungeonPriority > 0 then
        if ExecutePriority("dungeon", CFG.dungeonPriority) then return end
    end
    local sd = CFG.dungeonStandName and STAND_DATA[CFG.dungeonStandName]
    FireDungeon(sd and sd.normal or "Infinite Rotation")
end

-- ================================================================
-- [[ WORLD BOSS COMBAT ENGINE ]]
-- ================================================================
local function RunWorldBossTick()
    if GlobalCombatRules("wb") then return end
    if ShouldRest("wb") then FireWB("Rest"); return end
    if #CFG.wbPriority > 0 then
        if ExecutePriority("wb", CFG.wbPriority) then return end
    end
    local sd = CFG.wbStandName and STAND_DATA[CFG.wbStandName]
    FireWB(sd and sd.normal or "Infinite Rotation")
end

-- ================================================================
-- [[ WORLD BOSS SCANNER & FIGHT ]]
-- ================================================================
local WorldBossPriority = false
local WBSnapStand, WBSnapStyle = nil, nil

local function GetEngageBtnText()
    local btn = GamePath("WorldBossFrame","MenuContainer","InfoCard","EngageBtn")
    return btn and (btn.Text or "") or ""
end

local function GetWBTimerSecs()
    local lbl = GamePath("WorldBossFrame","MenuContainer","InfoCard","TimerLabel")
    if not lbl then return nil end
    local m,s = (lbl.Text or ""):match("(%d+):(%d+)")
    if not m then return nil end
    return tonumber(m)*60 + tonumber(s)
end

local function RunWorldBossFight()
    WBSnapStand = GetEquippedStandName()
    WBSnapStyle = GetEquippedStyleName()
    if CFG.wbStandName then EnsureStand(CFG.wbStandName) end
    if CFG.wbStyleName then EnsureStyle(CFG.wbStyleName) end
    EngageWB()
    local turnLabel = GamePath("WorldBossFrame","CombatMainFrame","TurnLabel")
    local waited = 0
    while waited < 8 and not ScriptKilled do
        task.wait(0.3); waited += 0.3
        if turnLabel and (turnLabel.Text or ""):find("Turns Remaining:") then break end
    end
    local logText = GamePath("WorldBossFrame","CombatMainFrame","ContentContainer","ChatboxArea","ChatScroll","LogText")
    local elapsed = 0
    while elapsed < 120 and not ScriptKilled do
        if logText and ((logText.Text or ""):find("Total Damage Dealt:") or (logText.Text or ""):find("Loot Secured")) then break end
        if turnLabel then
            local rem = tonumber((turnLabel.Text or ""):match("Turns Remaining:%s*(%d+)"))
            if rem and rem <= 0 then break end
        end
        RunWorldBossTick()
        task.wait(0.25); elapsed += 0.25
    end
    if WBSnapStand and WBSnapStand ~= "" then EnsureStand(WBSnapStand) end
    if WBSnapStyle and WBSnapStyle ~= "" then EnsureStyle(WBSnapStyle) end
    WorldBossPriority = false
end

local function RunWorldBossScanner(getEnabled)
    if GetEngageBtnText():upper():find("ENGAGE BOSS") then WorldBossPriority = true end
    while getEnabled() and not ScriptKilled do
        task.wait(2)
        local et = GetEngageBtnText():upper()
        if et:find("ENGAGE BOSS") then
            WorldBossPriority = true
        elseif et:find("WAITING") or et:find("ALREADY FOUGHT") then
            WorldBossPriority = false
            local secs = GetWBTimerSecs()
            if secs and secs > 0 then
                local slept = 0
                while slept < secs + 5 and getEnabled() and not ScriptKilled do
                    task.wait(1); slept += 1
                end
            end
        end
    end
end

