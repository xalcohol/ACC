    yOff+=16; local lH=160

    local poolF=Instance.new("Frame",PopupFrame); poolF.Size=UDim2.new(0.5,-10,0,lH); poolF.Position=UDim2.new(0,9,0,yOff)
    poolF.BackgroundColor3=C.bgCard; poolF.BorderSizePixel=0; poolF.ClipsDescendants=true; poolF.ZIndex=52; Corner(poolF,6); Stroke(poolF,C.divider,1)
    local pLL=Instance.new("UIListLayout",poolF); pLL.SortOrder=Enum.SortOrder.LayoutOrder; pLL.Padding=UDim.new(0,2)
    local pPd=Instance.new("UIPadding",poolF); pPd.PaddingTop=UDim.new(0,3); pPd.PaddingLeft=UDim.new(0,3); pPd.PaddingRight=UDim.new(0,3)

    local qF=Instance.new("Frame",PopupFrame); qF.Size=UDim2.new(0.5,-10,0,lH); qF.Position=UDim2.new(0.5,1,0,yOff)
    qF.BackgroundColor3=C.bgCard; qF.BorderSizePixel=0; qF.ClipsDescendants=true; qF.ZIndex=52; Corner(qF,6); Stroke(qF,C.divider,1)
    local qLL=Instance.new("UIListLayout",qF); qLL.SortOrder=Enum.SortOrder.LayoutOrder; qLL.Padding=UDim.new(0,2)
    local qPd=Instance.new("UIPadding",qF); qPd.PaddingTop=UDim.new(0,3); qPd.PaddingLeft=UDim.new(0,3); qPd.PaddingRight=UDim.new(0,3)

    local function RebuildQueue()
        for _,c in ipairs(qF:GetChildren()) do if c:IsA("TextButton") or c:IsA("Frame") then c:Destroy() end end
        for i,m in ipairs(ordered) do
            local row=Instance.new("Frame",qF); row.Size=UDim2.new(1,0,0,24); row.BackgroundColor3=C.bgSecond
            row.BorderSizePixel=0; row.LayoutOrder=i; row.ZIndex=53; Corner(row,4)
