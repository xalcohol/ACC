-- [[ COMBAT ENGINE — WORLD BOSS ]]
-- Runs CFG.wbPriority list, then falls back to normal attack
-- ================================================================
local function RunWorldBossTick()
    if HandleSurvival(WorldBossCtx) then return end
    if ShouldRest(WorldBossCtx)     then WorldBossUseSkill("Rest"); return end

    local energy, stamina = GetResources(WorldBossCtx)
    local hasEnergy  = energy  >= ENERGY_T
    local hasStamina = stamina >= STAMINA_T

    if #CFG.wbPriority > 0 then
        for _, moveName in ipairs(CFG.wbPriority) do
            if CanUse(WorldBossCtx, moveName) then
                local st = nil
                if CFG.wbStandName and STAND_DATA[CFG.wbStandName] then
                    for _, m in ipairs(STAND_DATA[CFG.wbStandName].moves) do
                        if m.name == moveName then st = m.statusType; break end
                    end
                end
                if not st and CFG.wbStyleName and STYLE_DATA[CFG.wbStyleName] then
                    for _, m in ipairs(STYLE_DATA[CFG.wbStyleName].moves) do
                        if m.name == moveName then st = m.statusType; break end
                    end
                end
                local skip = false
                if st == "confusion" and (EnemyIsConfImmune(WorldBossCtx) or EnemyIsConfused(WorldBossCtx)) then skip = true end
                if st == "stun"      and (EnemyIsStunImmune(WorldBossCtx) or EnemyIsStunned(WorldBossCtx))  then skip = true end
                if st == "burn"      and EnemyIsBurning(WorldBossCtx)                                        then skip = true end
                if st == "bleed"     and EnemyIsBleeding(WorldBossCtx)                                       then skip = true end
                if not skip then UseSkill(WorldBossCtx, moveName); return end
            end
        end
    end

    local sd = CFG.wbStandName and STAND_DATA[CFG.wbStandName]
    if hasEnergy and CanUse(WorldBossCtx, sd and sd.normal or "Infinite Rotation") then
        UseSkill(WorldBossCtx, sd and sd.normal or "Infinite Rotation"); return
    end

    WorldBossUseSkill("Rest")
end

