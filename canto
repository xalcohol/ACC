function IsInStoryBattle()
    return SafeGet(StoryCtx.Root(), "HealthbarArea","AlliesContainer","Fighter_Player")
        and SafeGet(StoryCtx.Root(), "HealthbarArea","EnemiesContainer","Fighter_Enemy")
end

function IsInDungeonBattle()
    return SafeGet(DungeonCtx.Root(), "HealthbarArea","AlliesContainer","Fighter_Player")
        and SafeGet(DungeonCtx.Root(), "HealthbarArea","EnemiesContainer","Fighter_Enemy")
end

function TryFleeFromDungeon()
    if not CanDo("Flee", 1) then return false end
    DungeonUseSkill("Flee")
    task.wait(0.5)
    return true
end

-- ================================================================
-- [[ COOLDOWN FIX ]]
-- ================================================================
local function CanUse(ctx, skillName)
    local btn = GetMoveButton(ctx, skillName)
    if not btn then return false end
    local text = btn.Text or btn.Name
    return not text:match("%(%d+%)")
end

-- ================================================================
-- [[ SAFE FLEE ]]
-- ================================================================
local function FleeAnyActiveBattle()
    if not CanDo("Flee", 1) then return end

    if IsInStoryBattle() then
        StoryUseSkill("Flee")
        task.wait(1)
    elseif IsInDungeonBattle() then
        TryFleeFromDungeon()
        task.wait(0.5)
    end
end

