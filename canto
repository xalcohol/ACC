-- ================================================================
local function EnsureStand(targetName)
    if not targetName or targetName == "" then return end
    if GetEquippedStandName():lower() == targetName:lower() then return end
    local slot = FindStandSlotByName(targetName)
    if not slot then return end
    StandStorageAction:FireServer("Swap", slot)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited = waited + 0.3
        if GetEquippedStandName():lower() == targetName:lower() then return end
    end
end

local function EnsureStyle(targetName)
    if not targetName or targetName == "" then return end
    if GetEquippedStyleName():lower() == targetName:lower() then return end
    local slot = FindStyleSlotByName(targetName)
    if not slot then return end
    SwapStyle(slot)
    local waited = 0
    while waited < 5 do
        task.wait(0.3); waited = waited + 0.3
        if GetEquippedStyleName():lower() == targetName:lower() then return end
    end
end

