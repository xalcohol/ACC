-- ================================================================
-- [[ PATH HELPERS ]]
-- ================================================================
local function SafeGet(root, ...)
    local cur = root
    for _, n in ipairs({...}) do
        if not cur then return nil end
        cur = cur:FindFirstChild(n)
    end
    return cur
end

local function ResolveRoot(pathStr)
    local node = PlayerGui
    for part in pathStr:gmatch("[^%.]+") do
        if not node then return nil end
        node = node:FindFirstChild(part)
    end
    return node
end

-- ================================================================
-- [[ COMBAT CONTEXTS ]]
-- ================================================================
local BASE         = "JJBIMenu.MainFrame.ContentContainer.SingleplayerFrame.MainPanel.InnerContent.ContentArea"
local STORY_ROOT   = BASE .. ".StoryFrame.CombatMainFrame.ContentContainer"
local DUNGEON_ROOT = BASE .. ".DungeonFrame.CombatMainFrame.ContentContainer"
local WBOSS_ROOT   = BASE .. ".WorldBossFrame.CombatMainFrame.ContentContainer"

local function MakeContext(rootPath, useSkillFn)
    return {
        Root              = function() return ResolveRoot(rootPath) end,
        UseSkill          = useSkillFn,
        HasBlockedThisDip = false,
    }
end

local StoryCtx     = MakeContext(STORY_ROOT,   StoryUseSkill)
local DungeonCtx   = MakeContext(DUNGEON_ROOT, DungeonUseSkill)
local WorldBossCtx = MakeContext(WBOSS_ROOT,   WorldBossUseSkill)

-- ================================================================
-- [[ FIXED STAND SCANNER ]]
-- ================================================================
local function StripRichText(text)
    local clean = text:gsub("<[^>]+>", "")
    clean = clean:gsub("%s+", " ")
    return clean:match("^%s*(.-)%s*$")
end

local function ScanStandSlots()
    local container = SafeGet(PlayerGui, table.unpack(STAND_STORAGE_PATH))
    if not container then return {} end

    local slots = {}
    local slotIndex = 1

    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            local nameLabel = child:FindFirstChild("NameLabel")
            local rawText = nameLabel and (nameLabel.Text or "") or ""
            local name = StripRichText(rawText)

            if name ~= "" and not name:find("Locked") then
                table.insert(slots, { name = name, slot = slotIndex })
                slotIndex = slotIndex + 1
            end
        end
    end

    return slots
end

local function FindStandSlot(targetName)
    local slots = ScanStandSlots()
    for _, entry in ipairs(slots) do
        if entry.name:lower() == targetName:lower() then
            return entry.slot
        end
    end
    return nil
end

