local function IsBokuNoRhythm()
    local btn = SafeGet(StoryCtx.Root(), "ButtonContainer", "StoryEncounterBtn")
    if not btn then return false end
    for _, obj in ipairs(btn:GetDescendants()) do
        if (obj:IsA("TextLabel") or obj:IsA("TextButton")) and (obj.Text or ""):find("Boku no Rhythm") then
            return true
        end
    end
    return false
end

-- ================================================================
-- [[ STORY LOOP ]]
-- ================================================================
local DungeonEnabled  = false
local PrestigeEnabled = CFG.prestigeEnabled

local function RunStoryLoop()
    EnsureStand(CFG.storyStandName)
    EnsureStyle(LOCKED_STYLE)
    DungeonAction:FireServer("Attack", "Flee")
    task.wait(0.5)

    if IsInStoryBattle() then
        RunStoryBattleLoop(function() return StoryEnabled end)
        task.wait(ACTION_CD)
        if WorldBossPriority then RunWorldBossFight() end
    end

    task.spawn(RunWorldBossScanner)

    while StoryEnabled and not ScriptKilled do
        if WorldBossPriority then
            if IsInStoryBattle() then
                RunStoryBattleLoop(function() return StoryEnabled end)
                task.wait(ACTION_CD)
            end
            RunWorldBossFight()
            task.wait(ACTION_CD)

        elseif PrestigeEnabled and IsBokuNoRhythm() then
            FirePrestige()
            task.wait(ACTION_CD)

        else
            CombatAction:FireServer("EngageStory")
            task.wait(ACTION_CD)
            RunStoryBattleLoop(function() return StoryEnabled end)
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

-- ================================================================
-- [[ DUNGEON LOOP ]]
-- ================================================================
local function RunDungeonLoop()
    if IsInStoryBattle() then
        CombatAction:FireServer("Attack", { SkillName = "Flee" })
        task.wait(1)
    end

    EnsureStand(CFG.dungeonStandName)
    EnsureStyle(LOCKED_STYLE)

    while DungeonEnabled and not ScriptKilled do
        if CFG.dailyModeOn and CFG.dailyFloor then
            local floor = GetDungeonFloor()
            if floor > CFG.dailyFloor then
                DungeonAction:FireServer("Attack", "Flee")
                task.wait(0.5)
                DungeonEnabled = false
                StoryEnabled   = true
                task.spawn(RunStoryLoop)
                return
            end
        end

        if not IsInDungeonBattle() then
            StartDungeon()
            task.wait(ACTION_CD)
            local waited = 0
            while not IsInDungeonBattle() and waited < 5 do
                task.wait(0.2); waited = waited + 0.2
            end
        end

        while DungeonEnabled and not ScriptKilled and IsInDungeonBattle() do
            if CFG.dailyModeOn and CFG.dailyFloor then
                local floor = GetDungeonFloor()
                if floor > CFG.dailyFloor then
                    DungeonAction:FireServer("Attack", "Flee")
                    task.wait(0.5)
                    DungeonEnabled = false
                    StoryEnabled   = true
                    task.spawn(RunStoryLoop)
                    return
                end
            end
            RunDungeonCombatTick()
            task.wait(ACTION_CD)
        end

        task.wait(ACTION_CD)
    end
end

