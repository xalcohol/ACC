-- ================================================================
local function CanUse(ctx, skillName)
    local area = SafeGet(ctx.Root(), "AbilitiesArea")
    if not area then return false end
    for _, btn in ipairs(area:GetChildren()) do
        if btn:IsA("TextButton") then
            local base = btn.Name:match("^(.-)%s*%(%d+%)%s*$") or btn.Name
            if base == skillName then
                return not btn.Name:match("%(%d+%)")
            end
        end
    end
    return false
end

local function UseSkill(ctx, name)
    ctx.UseSkill(name)
end

-- ================================================================
-- [[ RESOURCE THRESHOLDS ]]
-- ================================================================
local ENERGY_T  = 35
local STAMINA_T = 30
local HP_HEAL   = 0.67

-- ================================================================
-- [[ SHARED SURVIVAL CHECK ]]
-- ================================================================
local function HandleSurvival(ctx)
    local _, _, hpPct = GetHP(ctx)

    if IsConfused(ctx)            then UseSkill(ctx, "Rest"); return true end
    if IsPlayerIncapacitated(ctx) then UseSkill(ctx, "Infinite Rotation"); return true end

    local styleName = GetEquippedStyleName()
    local styleData = STYLE_DATA[styleName]
    if styleData and styleData.healMove then
        if hpPct < HP_HEAL then
            if CanUse(ctx, styleData.healMove) then
                ctx.HasBlockedThisDip = false
                UseSkill(ctx, styleData.healMove)
                return true
            elseif not ctx.HasBlockedThisDip then
                ctx.HasBlockedThisDip = true
                if CanUse(ctx, "Block") then UseSkill(ctx, "Block"); return true end
            end
        else
            ctx.HasBlockedThisDip = false
        end
    end

    return false
end

local function ShouldRest(ctx)
    local energy, stamina = GetResources(ctx)
    return energy < ENERGY_T and stamina < STAMINA_T
end

-- ================================================================
-- [[ COMBAT ENGINE — STORY ]]
-- Pucci: Illusory Presence -> Golden Spin -> Infinite Rotation
-- Tooru (configurable priority list)
-- All others: Infinite Rotation only
-- ================================================================
local function RunStoryCombatTick()
    if HandleSurvival(StoryCtx) then return end
    if ShouldRest(StoryCtx)     then StoryUseSkill("Rest"); return end

    local energy, stamina = GetResources(StoryCtx)
    local hasEnergy  = energy  >= ENERGY_T
    local hasStamina = stamina >= STAMINA_T

    -- Pucci priority
    if IsEnricoP() and #CFG.pucciPriority > 0 then
        for _, moveName in ipairs(CFG.pucciPriority) do
            if CanUse(StoryCtx, moveName) then
                local st = nil
                for _, m in ipairs(STAND_DATA["Tusk of U"] and STAND_DATA["Tusk of U"].moves or {}) do
                    if m.name == moveName then st = m.statusType; break end
                end
                if not st then
                    local sd = STYLE_DATA[GetEquippedStyleName()]
                    if sd then
                        for _, m in ipairs(sd.moves) do
                            if m.name == moveName then st = m.statusType; break end
                        end
                    end
                end
                local skip = false
                if st == "confusion" and (EnemyIsConfImmune(StoryCtx) or EnemyIsConfused(StoryCtx))   then skip = true end
                if st == "stun"      and (EnemyIsStunImmune(StoryCtx) or EnemyIsStunned(StoryCtx))    then skip = true end
                if st == "burn"      and EnemyIsBurning(StoryCtx)                                      then skip = true end
                if st == "bleed"     and EnemyIsBleeding(StoryCtx)                                     then skip = true end
                if not skip then UseSkill(StoryCtx, moveName); return end
            end
        end
    end

    -- Tooru priority
    if IsTooru() and #CFG.tooruPriority > 0 then
        for _, moveName in ipairs(CFG.tooruPriority) do
            if CanUse(StoryCtx, moveName) then
                local st = nil
                for _, m in ipairs(STAND_DATA["Tusk of U"] and STAND_DATA["Tusk of U"].moves or {}) do
                    if m.name == moveName then st = m.statusType; break end
                end
                if not st then
                    local sd = STYLE_DATA[GetEquippedStyleName()]
                    if sd then
                        for _, m in ipairs(sd.moves) do
                            if m.name == moveName then st = m.statusType; break end
                        end
                    end
                end
                local skip = false
                if st == "confusion" and (EnemyIsConfImmune(StoryCtx) or EnemyIsConfused(StoryCtx))   then skip = true end
                if st == "stun"      and (EnemyIsStunImmune(StoryCtx) or EnemyIsStunned(StoryCtx))    then skip = true end
                if st == "burn"      and EnemyIsBurning(StoryCtx)                                      then skip = true end
                if st == "bleed"     and EnemyIsBleeding(StoryCtx)                                     then skip = true end
                if not skip then UseSkill(StoryCtx, moveName); return end
            end
        end
    end

    -- Normal attack filler
    local sd = CFG.storyStandName and STAND_DATA[CFG.storyStandName]
    if hasEnergy and CanUse(StoryCtx, sd and sd.normal or "Infinite Rotation") then
        UseSkill(StoryCtx, sd and sd.normal or "Infinite Rotation"); return
    end

    StoryUseSkill("Rest")
end

