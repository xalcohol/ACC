local function MakeOverlay(parent)
    local ov = Instance.new("Frame", parent)
    ov.Size                   = UDim2.new(1, 0, 1, 0)
    ov.BackgroundColor3       = BLACK
    ov.BackgroundTransparency = 0.55
    ov.BorderSizePixel        = 0
    ov.ZIndex                 = parent.ZIndex + 5
    ov.Visible                = false
    MakeCorner(ov, 6)
    return ov
end

