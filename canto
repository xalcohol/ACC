-- [[ DEBOUNCE SYSTEM ]] --
local Debounce = { Flee = 0, Swap = 0 }
local function CanDo(action, cd)
    if tick() - Debounce[action] >= cd then
        Debounce[action] = tick()
        return true
    end
    return false
end

