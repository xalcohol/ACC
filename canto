local function ShowPriorityBuilder(title, moves, currentPrio, onSave)
    local w  = C_W - 16
    local h  = 295
    OpenPopup(w, h)
    local yOff = AddPopupHeader(title)

    local ordered = {}
    for _, mn in ipairs(currentPrio or {}) do
        for _, m in ipairs(moves) do
            if m.name == mn then
                table.insert(ordered, m)
                break
            end
        end
    end

    local function GetPool()
        local pool = {}
        for _, m in ipairs(moves) do
            local found = false
            for _, om in ipairs(ordered) do
                if om.name == m.name then found = true; break end
            end
            if not found then table.insert(pool, m) end
        end
        return pool
    end

    local avlLbl = MakeLabel(PopupFrame, "Available", 9, T_SUB, Enum.Font.GothamBold)
    avlLbl.Size     = UDim2.new(0.5, -10, 0, 14)
    avlLbl.Position = UDim2.new(0, 9, 0, yOff)
    avlLbl.ZIndex   = 52

    local prioLbl = MakeLabel(PopupFrame, "Priority", 9, T_SUB, Enum.Font.GothamBold)
    prioLbl.Size     = UDim2.new(0.5, -10, 0, 14)
    prioLbl.Position = UDim2.new(0.5, 1, 0, yOff)
    prioLbl.ZIndex   = 52
    yOff = yOff + 16

    local listH = 158

    local poolF = Instance.new("Frame", PopupFrame)
    poolF.Size             = UDim2.new(0.5, -10, 0, listH)
    poolF.Position         = UDim2.new(0, 9, 0, yOff)
    poolF.BackgroundColor3 = BG_CARD
    poolF.BorderSizePixel  = 0
    poolF.ClipsDescendants = true
    poolF.ZIndex           = 52
    MakeCorner(poolF, 6)
    MakeStroke(poolF, DIVIDER, 1)
    local poolLayout = Instance.new("UIListLayout", poolF)
    poolLayout.SortOrder = Enum.SortOrder.LayoutOrder
    poolLayout.Padding   = UDim.new(0, 2)
    local poolPad = Instance.new("UIPadding", poolF)
    poolPad.PaddingTop   = UDim.new(0, 3)
    poolPad.PaddingLeft  = UDim.new(0, 3)
    poolPad.PaddingRight = UDim.new(0, 3)

    local queueF = Instance.new("Frame", PopupFrame)
    queueF.Size             = UDim2.new(0.5, -10, 0, listH)
    queueF.Position         = UDim2.new(0.5, 1, 0, yOff)
    queueF.BackgroundColor3 = BG_CARD
    queueF.BorderSizePixel  = 0
    queueF.ClipsDescendants = true
    queueF.ZIndex           = 52
    MakeCorner(queueF, 6)
    MakeStroke(queueF, DIVIDER, 1)
    local queueLayout = Instance.new("UIListLayout", queueF)
    queueLayout.SortOrder = Enum.SortOrder.LayoutOrder
    queueLayout.Padding   = UDim.new(0, 2)
    local queuePad = Instance.new("UIPadding", queueF)
    queuePad.PaddingTop   = UDim.new(0, 3)
    queuePad.PaddingLeft  = UDim.new(0, 3)
    queuePad.PaddingRight = UDim.new(0, 3)

    local RebuildPool
    local RebuildQueue

    RebuildQueue = function()
        for _, c in ipairs(queueF:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
        end
        for i, m in ipairs(ordered) do
            local row = Instance.new("Frame", queueF)
            row.Size             = UDim2.new(1, 0, 0, 24)
            row.BackgroundColor3 = BG2
            row.BorderSizePixel  = 0
            row.LayoutOrder      = i
            row.ZIndex           = 53
            MakeCorner(row, 4)

            local numLbl = MakeLabel(row, i .. ".", 9, ACCENT, Enum.Font.GothamBold)
            numLbl.Size     = UDim2.new(0, 16, 1, 0)
            numLbl.Position = UDim2.new(0, 3, 0, 0)
            numLbl.ZIndex   = 54

            local nameLbl = MakeLabel(row, m.name, 9, T_PRIM, Enum.Font.GothamMedium)
            nameLbl.Size         = UDim2.new(1, -38, 1, 0)
            nameLbl.Position     = UDim2.new(0, 20, 0, 0)
            nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
            nameLbl.ZIndex       = 54

            local rmBtn = MakeButton(row, "X", Color3.fromRGB(45, 12, 12), C_RED, 8)
            rmBtn.Size     = UDim2.new(0, 16, 0, 16)
            rmBtn.Position = UDim2.new(1, -19, 0.5, -8)
            rmBtn.ZIndex   = 54

            local capturedIdx = i
            rmBtn.MouseButton1Click:Connect(function()
                table.remove(ordered, capturedIdx)
                RebuildPool()
                RebuildQueue()
            end)
        end
    end

    RebuildPool = function()
        for _, c in ipairs(poolF:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        local pool = GetPool()
        for pi, pm in ipairs(pool) do
            local pb = MakeButton(poolF, pm.name, BG2, T_PRIM, 9)
            pb.Size         = UDim2.new(1, 0, 0, 24)
            pb.LayoutOrder  = pi
            pb.ZIndex       = 53
            pb.TextTruncate = Enum.TextTruncate.AtEnd
            local captured = pm
            pb.MouseButton1Click:Connect(function()
                table.insert(ordered, captured)
                pb:Destroy()
                RebuildQueue()
            end)
        end
    end

    RebuildPool()
    RebuildQueue()

    local saveBtn = MakeButton(PopupFrame, "Save Priority", ACCENT_S, T_PRIM, 11)
    saveBtn.Size     = UDim2.new(1, -18, 0, 28)
    saveBtn.Position = UDim2.new(0, 9, 0, yOff + listH + 6)
    saveBtn.ZIndex   = 52
    MakeStroke(saveBtn, ACCENT, 1)

    saveBtn.MouseButton1Click:Connect(function()
        local result = {}
        for _, m in ipairs(ordered) do
            table.insert(result, m.name)
        end
        onSave(result)
    end)
end

