-- ================================================================
-- [[ NAME FORMATTING ]]
-- ================================================================
local function StripRichText(text)
    local clean = text:gsub("<[^>]+>", "")
    clean = clean:gsub("%s+", " ")
    return clean:match("^%s*(.-)%s*$")
end

local function StripSlotPrefix(name)
    name = name:match("^S%d+:%s*(.+)$") or name
    name = name:match("^STAND:%s*(.+)$") or name
    name = name:match("^STYLE:%s*(.+)$") or name
    return name
end

local function FormatDropdownName(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    return clean:match("^%s*(.-)%s*$")
end

local STAND_ABBREV = {
    ["Tusk of U"]            = "TOU",
    ["Tusk Act 4"]           = "TA4",
    ["King Crimson Requiem"] = "KCR",
    ["King of U"]            = "KOU",
}

local function FormatStandLabel(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    clean = clean:match("^%s*(.-)%s*$")

    local traitCount = {}
    local traitOrder = {}
    for trait in clean:gmatch("%[([A-Z]+)%]") do
        local initial = trait:sub(1, 1)
        if not traitCount[initial] then
            table.insert(traitOrder, initial)
            traitCount[initial] = 0
        end
        traitCount[initial] = traitCount[initial] + 1
    end

    local base = clean:gsub("%s*%[%u+%]", ""):gsub("%s*&%s*", ""):match("^%s*(.-)%s*$")

    local baseUpper = base:upper()
    for full, short in pairs(STAND_ABBREV) do
        if baseUpper == full:upper() then
            base = short
            break
        end
    end

    local traitParts = {}
    for _, initial in ipairs(traitOrder) do
        local count = traitCount[initial]
        if count > 1 then
            table.insert(traitParts, initial .. count)
        else
            table.insert(traitParts, initial)
        end
    end

    if #traitParts > 0 then
        return base .. " [" .. table.concat(traitParts, "+") .. "]"
    end
    return base
end

local function FormatFullName(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    clean = clean:match("^%s*(.-)%s*$")

    local base = clean:gsub("%s*%[.-%]", ""):gsub("%s*&%s*", ""):match("^%s*(.-)%s*$")
    local traits = {}
    for trait in clean:gmatch("%[([^%]]+)%]") do
        local words = {}
        for word in trait:lower():gmatch("%S+") do
            word = word:sub(1,1):upper() .. word:sub(2)
            table.insert(words, word)
        end
        table.insert(traits, "[" .. table.concat(words, " ") .. "]")
    end

    local baseWords = {}
    for word in base:lower():gmatch("%S+") do
        local small = { of=true, the=true, a=true, an=true, and=true }
        if #baseWords == 0 or not small[word] then
            word = word:sub(1,1):upper() .. word:sub(2)
        end
        table.insert(baseWords, word)
    end
    base = table.concat(baseWords, " ")

    if #traits > 0 then
        return base .. " " .. table.concat(traits, " & ")
    end
    return base
end

local function GetBaseName(rawText)
    local clean = StripRichText(rawText)
    clean = StripSlotPrefix(clean)
    clean = clean:gsub("%s*%[.-%]", ""):gsub("%s*&%s*", ""):match("^%s*(.-)%s*$")
    local words = {}
    for word in clean:lower():gmatch("%S+") do
        local small = { of=true, the=true, a=true, an=true, and=true }
        if #words == 0 or not small[word] then
            word = word:sub(1,1):upper() .. word:sub(2)
        end
        table.insert(words, word)
    end
    return table.concat(words, " ")
end

