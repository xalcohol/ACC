local function ScanStandStorage()
    local container = SafeGet(PlayerGui, table.unpack(STAND_STORAGE_PATH))
    if not container then return {} end
    local slots = {}
    local slotNum = 0
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum = slotNum + 1
            local nl  = child:FindFirstChild("NameLabel")
            local raw = nl and (nl.Text or "") or ""
            local base = GetBaseName(raw)
            table.insert(slots, {
                slotNum  = slotNum,
                swapArg  = slotNum,
                fullName = FormatFullName(raw),
                baseName = base,
            })
        end
    end
    return slots
end

local function ScanStyleStorage()
    local container = SafeGet(PlayerGui, table.unpack(STYLE_STORAGE_PATH))
    if not container then return {} end
    local slots = {}
    local slotNum = 0
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("Frame") then
            slotNum = slotNum + 1
            local nl  = child:FindFirstChild("NameLabel")
            local raw = nl and (nl.Text or "") or ""
            local base = GetBaseName(raw)
            table.insert(slots, {
                slotNum  = slotNum,
                swapArg  = slotNum,
                fullName = FormatFullName(raw),
                baseName = base,
            })
        end
    end
    return slots
end

local function FindStandSlotByName(targetName)
    local slots = ScanStandStorage()
    for _, s in ipairs(slots) do
        if s.baseName:lower() == targetName:lower() then return s.swapArg end
    end
    return nil
end

local function FindStyleSlotByName(targetName)
    local slots = ScanStyleStorage()
    for _, s in ipairs(slots) do
        if s.baseName:lower() == targetName:lower() then return s.swapArg end
    end
    return nil
end

