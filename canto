-- ================================================================
-- [[ WORLD BOSS SCANNER & FIGHT ]]
-- ================================================================
local WorldBossPriority = false
local WBSnapStand       = nil
local WBSnapStyle       = nil

local function GetEngageBtnText()
    local btn = SafeGet(PlayerGui, table.unpack(WB_ENGAGE_PATH))
    return btn and (btn.Text or "") or ""
end

local function ParseTimerLabel()
    local lbl = SafeGet(PlayerGui, table.unpack(WB_TIMER_PATH))
    if not lbl then return nil end
    local m, s = (lbl.Text or ""):match("(%d+):(%d+)")
    if not m then return nil end
    return tonumber(m) * 60 + tonumber(s)
end

local StoryEnabled = false

local function WaitForBossTimer()
    while StoryEnabled and not ScriptKilled do
        local secs = ParseTimerLabel()
        if not secs or secs <= 0 then return end
        if secs > 30 * 60 then
            local elapsed = 0
            while elapsed < 1800 and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed = elapsed + 1
            end
        elseif secs > 10 * 60 then
            local elapsed = 0
            while elapsed < 600 and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed = elapsed + 1
            end
        else
            local elapsed = 0
            while elapsed < secs and StoryEnabled and not ScriptKilled do
                task.wait(1); elapsed = elapsed + 1
            end
            return
        end
    end
end

local function RunWorldBossScanner()
    local engageText = GetEngageBtnText()
    if not engageText:find("ENGAGE BOSS") then
        WaitForBossTimer()
    end

    while StoryEnabled and not ScriptKilled do
        local et = GetEngageBtnText()
        if et:find("ENGAGE BOSS") then
            WorldBossPriority = true
            while WorldBossPriority and StoryEnabled and not ScriptKilled do
                task.wait(1)
            end
            task.wait(10)
            WaitForBossTimer()
        elseif et:find("ALREADY FOUGHT") then
            task.wait(5)
            WaitForBossTimer()
        else
            task.wait(5)
            WaitForBossTimer()
        end
    end
end

local function RunWorldBossFight()
    WBSnapStand = GetEquippedStandName()
    WBSnapStyle = GetEquippedStyleName()

    if CFG.wbStandName then EnsureStand(CFG.wbStandName) end
    if CFG.wbStyleName then EnsureStyle(CFG.wbStyleName) end

    EngageWorldBoss()

    local turnLabel = SafeGet(PlayerGui, table.unpack(WB_TURN_PATH))
    local waited = 0
    local fightStarted = false
    while waited < 8 and not ScriptKilled do
        task.wait(0.3); waited = waited + 0.3
        if turnLabel and (turnLabel.Text or ""):find("Turns Remaining: 10/10") then
            fightStarted = true
            break
        end
    end

    if not fightStarted then
        WorldBossUseSkill("Infinite Rotation")
        task.wait(1)
    end

    local logText = SafeGet(PlayerGui, table.unpack(WB_LOG_PATH))
    WorldBossCtx.HasBlockedThisDip = false
    task.wait(0.5)

    local elapsed  = 0
    local finished = false
    while elapsed < 120 and not ScriptKilled and not finished do
        if logText then
            local log = logText.Text or ""
            if log:find("Damage Dealt:") or log:find("Loot Secured") then
                finished = true
                break
            end
        end
        if turnLabel then
            local rem = tonumber((turnLabel.Text or ""):match("Turns Remaining:%s*(%d+)"))
            if rem and rem <= 0 then finished = true; break end
        end
        RunWorldBossTick()
        task.wait(ACTION_CD)
        elapsed = elapsed + ACTION_CD
    end

    WorldBossCtx.HasBlockedThisDip = false

    if WBSnapStand and WBSnapStand ~= "" then EnsureStand(WBSnapStand) end
    if WBSnapStyle and WBSnapStyle ~= "" then EnsureStyle(WBSnapStyle) end

    WorldBossPriority = false
end

