    btn.MouseEnter:Connect(function()
        if btn.BackgroundColor3 == normal then btn.BackgroundColor3 = hover end
    end)
    btn.MouseLeave:Connect(function()
        if btn.BackgroundColor3 == hover then btn.BackgroundColor3 = normal end
    end)
end

