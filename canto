-- Runs CFG.dungeonPriority list, then falls back to normal attack
-- ================================================================
local function RunDungeonCombatTick()
    if HandleSurvival(DungeonCtx) then return end
    if ShouldRest(DungeonCtx)     then DungeonUseSkill("Rest"); return end

    local energy, stamina = GetResources(DungeonCtx)
    local hasEnergy  = energy  >= ENERGY_T
    local hasStamina = stamina >= STAMINA_T

    if #CFG.dungeonPriority > 0 then
        for _, moveName in ipairs(CFG.dungeonPriority) do
            if CanUse(DungeonCtx, moveName) then
                local st = nil
                for _, m in ipairs(STAND_DATA["Tusk of U"] and STAND_DATA["Tusk of U"].moves or {}) do
                    if m.name == moveName then st = m.statusType; break end
                end
                if not st then
                    local sd = STYLE_DATA[GetEquippedStyleName()]
                    if sd then
                        for _, m in ipairs(sd.moves) do
                            if m.name == moveName then st = m.statusType; break end
                        end
                    end
                end
                local skip = false
                if st == "confusion" and (EnemyIsConfImmune(DungeonCtx) or EnemyIsConfused(DungeonCtx)) then skip = true end
                if st == "stun"      and (EnemyIsStunImmune(DungeonCtx) or EnemyIsStunned(DungeonCtx))  then skip = true end
                if st == "burn"      and EnemyIsBurning(DungeonCtx)                                      then skip = true end
                if st == "bleed"     and EnemyIsBleeding(DungeonCtx)                                     then skip = true end
                if not skip then UseSkill(DungeonCtx, moveName); return end
            end
        end
    end

    local sd = CFG.dungeonStandName and STAND_DATA[CFG.dungeonStandName]
    if hasEnergy and CanUse(DungeonCtx, sd and sd.normal or "Infinite Rotation") then
        UseSkill(DungeonCtx, sd and sd.normal or "Infinite Rotation"); return
    end

    DungeonUseSkill("Rest")
end

